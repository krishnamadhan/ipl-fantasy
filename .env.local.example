NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
RAPIDAPI_KEY=your_rapidapi_key_for_cricbuzz
CRON_SECRET=a-long-random-secret-for-cron-auth
NEXT_PUBLIC_URL=https://your-ipl-fantasy-app.vercel.app

# Claude API — used as fallback for playing XI extraction when Cricbuzz parsing fails
ANTHROPIC_API_KEY=your_anthropic_api_key


# ── Bot Integration ──────────────────────────────────────────────────────────
# Shared secret for BanterAgent → Fantasy app communication
# Must match FANTASY_BOT_SECRET in banteragent's .env
BOT_SECRET=a-long-random-secret-string
# Public URL of this app (used by bot/playing-xi POST to call sync-squads internally)
NEXT_PUBLIC_APP_URL=https://your-ipl-fantasy-app.vercel.app
